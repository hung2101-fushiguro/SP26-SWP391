<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="false">

    <display-name>ClickEat Merchant API</display-name>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ================================================================
         FILTERS  (order matters: CORS must run before JWT Auth)
         ================================================================ -->

    <!-- 1. CORS Filter -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.clickeat.filter.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- 2. JWT Authentication Filter -->
    <filter>
        <filter-name>JwtAuthFilter</filter-name>
        <filter-class>com.clickeat.filter.JwtAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>JwtAuthFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ================================================================
         SERVLETS  (annotation-scanned because metadata-complete="false")
         Explicit declarations here override @WebServlet load order only.
         ================================================================ -->

    <!-- Auth -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.AuthServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>

    <!-- Dashboard -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.DashboardServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/api/dashboard/*</url-pattern>
    </servlet-mapping>

    <!-- Categories -->
    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.CategoryServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/api/categories/*</url-pattern>
    </servlet-mapping>

    <!-- Menu Items -->
    <servlet>
        <servlet-name>MenuItemServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.MenuItemServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>MenuItemServlet</servlet-name>
        <url-pattern>/api/menu-items/*</url-pattern>
    </servlet-mapping>

    <!-- Orders -->
    <servlet>
        <servlet-name>OrderServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.OrderServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/api/orders/*</url-pattern>
    </servlet-mapping>

    <!-- Reviews -->
    <servlet>
        <servlet-name>ReviewServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.ReviewServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReviewServlet</servlet-name>
        <url-pattern>/api/reviews/*</url-pattern>
    </servlet-mapping>

    <!-- Settings -->
    <servlet>
        <servlet-name>SettingsServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.SettingsServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>SettingsServlet</servlet-name>
        <url-pattern>/api/settings/*</url-pattern>
    </servlet-mapping>

    <!-- Notifications -->
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.NotificationServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/api/notifications/*</url-pattern>
    </servlet-mapping>

    <!-- Vouchers -->
    <servlet>
        <servlet-name>VoucherServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.VoucherServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoucherServlet</servlet-name>
        <url-pattern>/api/vouchers/*</url-pattern>
    </servlet-mapping>

    <!-- Analytics -->
    <servlet>
        <servlet-name>AnalyticsServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.AnalyticsServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnalyticsServlet</servlet-name>
        <url-pattern>/api/analytics/*</url-pattern>
    </servlet-mapping>

    <!-- Wallet -->
    <servlet>
        <servlet-name>WalletServlet</servlet-name>
        <servlet-class>com.clickeat.servlet.WalletServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>WalletServlet</servlet-name>
        <url-pattern>/api/wallet/*</url-pattern>
    </servlet-mapping>

    <!-- ================================================================
         WELCOME FILE (SPA entry point)
         ================================================================ -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ================================================================
         ERROR PAGES
         ================================================================ -->
    <error-page>
        <error-code>404</error-code>
        <location>/index.html</location>
    </error-page>

</web-app>
